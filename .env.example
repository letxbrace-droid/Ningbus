# Copy this file to .env for local development
# Never commit .env to Git !

# Required — Groq API key (https://console.groq.com/) — 100% GRATUIT
GROQ_API_KEY=gsk_...

# Optional — Groq model override (default: llama-3.1-70b-versatile)
# Other options: llama-3.3-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it
GROQ_MODEL=llama-3.1-70b-versatile

# Optional — Bright Data proxy (https://brightdata.com/)
BRIGHT_DATA_TOKEN=your-brightdata-customer-id

# Optional — SerpAPI key (https://serpapi.com/) for product search fallback
SERPAPI_KEY=your-serpapi-key

# Optional — logging verbosity (DEBUG | INFO | WARNING)
LOG_LEVEL=INFO
