# Copy this file to .env for local development
# Never commit .env to Git !

# ── OBLIGATOIRE ────────────────────────────────────────────────
# Meta Ad Library API token (GRATUIT)
# Setup en 5 min : voir README section "Setup Meta Token"
META_ACCESS_TOKEN=EAAxxxxxxxxxxxxxx

# Groq API key (GRATUIT) — https://console.groq.com/
GROQ_API_KEY=gsk_...

# ── OPTIONNEL ──────────────────────────────────────────────────
# Groq model override
GROQ_MODEL=llama-3.1-70b-versatile

# SerpAPI key for product search fallback
SERPAPI_KEY=your-serpapi-key

# Logging verbosity
LOG_LEVEL=INFO
